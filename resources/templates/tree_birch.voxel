# Full-height trunk visible below canopy. Oval canopy: narrow base, wide middle, narrow top.

# --- TRUNK (Y=0, center, full height sy=0,1,2) ---
S 0 0 0  1 0 1  Wood
S 0 0 0  1 1 1  Wood
S 0 0 0  1 2 1  Wood

# --- CANOPY BASE (Y=1, sy=0, cross — narrow) ---
S 0 1 0  1 0 0  Leaf
S 0 1 0  0 0 1  Leaf
S 0 1 0  1 0 1  Leaf
S 0 1 0  2 0 1  Leaf
S 0 1 0  1 0 2  Leaf

# --- CANOPY MIDDLE (Y=1, sy=1, full 3x3 — wide) ---
S 0 1 0  0 1 0  Leaf
S 0 1 0  1 1 0  Leaf
S 0 1 0  2 1 0  Leaf
S 0 1 0  0 1 1  Leaf
S 0 1 0  1 1 1  Leaf
S 0 1 0  2 1 1  Leaf
S 0 1 0  0 1 2  Leaf
S 0 1 0  1 1 2  Leaf
S 0 1 0  2 1 2  Leaf

# --- CANOPY TOP (Y=1, sy=2, cross — narrow) ---
S 0 1 0  1 2 0  Leaf
S 0 1 0  0 2 1  Leaf
S 0 1 0  1 2 1  Leaf
S 0 1 0  2 2 1  Leaf
S 0 1 0  1 2 2  Leaf
