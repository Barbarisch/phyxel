# --- LEGS (sy=0, floor to seat bottom: Y=0 to Y=0.333) ---
S 0 0 0  0 0 0  Wood
S 0 0 0  1 0 0  Wood
S 0 0 0  0 0 1  Wood
S 0 0 0  1 0 1  Wood

# --- SEAT (sy=1, seat slab: Y=0.333 to Y=0.667) ---
S 0 0 0  0 1 0  Wood
S 0 0 0  1 1 0  Wood
S 0 0 0  0 1 1  Wood
S 0 0 0  1 1 1  Wood

# --- BACK LEG BRIDGE (sy=2 in cube Y=0: Y=0.667 to Y=1.0, sz=0, connects seat to backrest) ---
S 0 0 0  0 2 0  Wood
S 0 0 0  1 2 0  Wood

# --- BACK LEG POSTS (sy=0 in cube Y=1: Y=1.0 to Y=1.333, sz=0) ---
S 0 1 0  0 0 0  Wood
S 0 1 0  1 0 0  Wood

# --- BACKREST (sy=1,2 in cube Y=1: Y=1.333 to Y=2.0, sz=0) ---
