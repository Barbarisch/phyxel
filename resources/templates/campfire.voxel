# --- STONE RING (sy=0, cardinal positions) ---
S 0 0 0  1 0 0  Stone
S 0 0 0  0 0 1  Stone
S 0 0 0  2 0 1  Stone
S 0 0 0  1 0 2  Stone

# --- CROSSED LOGS (sy=0, diagonal corners) ---
S 0 0 0  0 0 0  Wood
S 0 0 0  2 0 0  Wood
S 0 0 0  0 0 2  Wood
S 0 0 0  2 0 2  Wood

# --- EMBERS + FLAME (glow) ---
S 0 0 0  1 0 1  glow
S 0 0 0  1 1 1  glow
S 0 1 0  1 0 1  glow
