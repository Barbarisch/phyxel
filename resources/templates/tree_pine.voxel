# Trunk at center, 3 progressively narrowing branch tiers: full → cross → cross → tip.

# --- TRUNK (Y=0, sy=0) ---
S 0 0 0  1 0 1  Log

# --- BOTTOM TIER (Y=0, sy=1, full 3x3) ---
S 0 0 0  0 1 0  Leaf
S 0 0 0  1 1 0  Leaf
S 0 0 0  2 1 0  Leaf
S 0 0 0  0 1 1  Leaf
S 0 0 0  1 1 1  Leaf
S 0 0 0  2 1 1  Leaf
S 0 0 0  0 1 2  Leaf
S 0 0 0  1 1 2  Leaf
S 0 0 0  2 1 2  Leaf

# --- SECOND TIER (Y=0, sy=2, cross) ---
S 0 0 0  1 2 0  Leaf
S 0 0 0  0 2 1  Leaf
S 0 0 0  1 2 1  Leaf
S 0 0 0  2 2 1  Leaf
S 0 0 0  1 2 2  Leaf

# --- TRUNK (Y=1, sy=0) ---
S 0 1 0  1 0 1  Log

# --- MID TIER (Y=1, sy=1, cross) ---
S 0 1 0  1 1 0  Leaf
S 0 1 0  0 1 1  Leaf
S 0 1 0  1 1 1  Leaf
S 0 1 0  2 1 1  Leaf
S 0 1 0  1 1 2  Leaf

# --- UPPER TIER (Y=1, sy=2, cross) ---
S 0 1 0  1 2 0  Leaf
S 0 1 0  0 2 1  Leaf
S 0 1 0  1 2 1  Leaf
S 0 1 0  2 2 1  Leaf
S 0 1 0  1 2 2  Leaf

# --- TIP (Y=2, sy=0, center) ---
S 0 2 0  1 0 1  Leaf
