# Trunk sy=0+1 at center, canopy flare at sy=2, full dome in Y=1.

# --- TRUNK (Y=0, center, sy=0+1) ---
S 0 0 0  1 0 1  Log
S 0 0 0  1 1 1  Log

# --- CANOPY FLARE (Y=0, sy=2, cross) ---
S 0 0 0  1 2 0  Leaf
S 0 0 0  0 2 1  Leaf
S 0 0 0  1 2 1  Leaf
S 0 0 0  2 2 1  Leaf
S 0 0 0  1 2 2  Leaf

# --- CANOPY BASE (Y=1, sy=0, full 3x3) ---
S 0 1 0  0 0 0  Leaf
S 0 1 0  1 0 0  Leaf
S 0 1 0  2 0 0  Leaf
S 0 1 0  0 0 1  Leaf
S 0 1 0  1 0 1  Leaf
S 0 1 0  2 0 1  Leaf
S 0 1 0  0 0 2  Leaf
S 0 1 0  1 0 2  Leaf
S 0 1 0  2 0 2  Leaf

# --- CANOPY DOME (Y=1, sy=1, cross) ---
S 0 1 0  1 1 0  Leaf
S 0 1 0  0 1 1  Leaf
S 0 1 0  1 1 1  Leaf
S 0 1 0  2 1 1  Leaf
S 0 1 0  1 1 2  Leaf

# --- CANOPY TOP (Y=1, sy=2, center) ---
S 0 1 0  1 2 1  Leaf
