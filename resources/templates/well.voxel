# Stone ring = 8 outer subcubes per layer (no center = open shaft).
# Wooden crossbeam spans full width at top.

# --- RING LAYER 1 (sy=0) ---
S 0 0 0  0 0 0  Stone
S 0 0 0  1 0 0  Stone
S 0 0 0  2 0 0  Stone
S 0 0 0  0 0 1  Stone
S 0 0 0  2 0 1  Stone
S 0 0 0  0 0 2  Stone
S 0 0 0  1 0 2  Stone
S 0 0 0  2 0 2  Stone

# --- RING LAYER 2 (sy=1) ---
S 0 0 0  0 1 0  Stone
S 0 0 0  1 1 0  Stone
S 0 0 0  2 1 0  Stone
S 0 0 0  0 1 1  Stone
S 0 0 0  2 1 1  Stone
S 0 0 0  0 1 2  Stone
S 0 0 0  1 1 2  Stone
S 0 0 0  2 1 2  Stone

# --- RING LAYER 3 / RIM (sy=2) ---
S 0 0 0  0 2 0  Stone
S 0 0 0  1 2 0  Stone
S 0 0 0  2 2 0  Stone
S 0 0 0  0 2 1  Stone
S 0 0 0  2 2 1  Stone
S 0 0 0  0 2 2  Stone
S 0 0 0  1 2 2  Stone
S 0 0 0  2 2 2  Stone

# --- CROSSBEAM (Y=1, sy=0, spans full width at center depth) ---
S 0 1 0  0 0 1  Wood
S 0 1 0  1 0 1  Wood
S 0 1 0  2 0 1  Wood
