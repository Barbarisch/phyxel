  "npcs": [
    {
      "name": "Elder_Frostbeard",
      "position": {"x": 25, "y": 22, "z": 25},
      "behavior": "idle",
      "dialogue": {
        "id": "elder_talk",
        "startNodeId": "greet",
        "nodes": [
          {
            "id": "greet",
            "speaker": "Elder Frostbeard",
            "text": "Welcome to Highland Village, stranger. These mountains hold many secrets.",
            "choices": [
              {"text": "What secrets?", "nextNodeId": "secrets"},
              {"text": "I'm looking for the lost expedition.", "nextNodeId": "expedition"}
            ]
          },
          {
            "id": "secrets",
            "speaker": "Elder Frostbeard",
            "text": "There is a frozen temple far to the northwest. It glows with an unearthly light. No one who has entered has returned.",
            "choices": [
              {"text": "Tell me about the expedition.", "nextNodeId": "expedition"},
              {"text": "I'll find it myself.", "nextNodeId": "farewell"}
            ]
          },
          {
            "id": "expedition",
            "speaker": "Elder Frostbeard",
            "text": "A group of explorers went to the temple weeks ago. The Ranger may know their last known position. She patrols the village perimeter.",
            "choices": [
              {"text": "I'll speak with her.", "nextNodeId": "farewell"}
            ]
          },
          {
            "id": "farewell",
            "speaker": "Elder Frostbeard",
            "text": "Be careful out there. The cold is not the only danger on these peaks."
          }
        ]
      },
      "storyCharacter": {
        "id": "elder",
        "faction": "highland_village",
        "agencyLevel": 1,
        "traits": {
          "openness": 0.6,
          "conscientiousness": 0.9,
          "extraversion": 0.4,
          "agreeableness": 0.8,
          "neuroticism": 0.3
        },
        "goals": [
          {"id": "protect_village", "description": "Protect Highland Village from threats", "priority": 0.95},
          {"id": "find_expedition", "description": "Learn the fate of the lost expedition", "priority": 0.7}
        ],
        "roles": ["quest_giver", "village_leader"]
      }
    },
    {
      "name": "Ranger_Kira",
      "position": {"x": 40, "y": 22, "z": 25},
      "behavior": "patrol",
      "waypoints": [
        {"x": 40, "y": 22, "z": 25},
        {"x": 50, "y": 22, "z": 25},
        {"x": 50, "y": 22, "z": 45},
        {"x": 14, "y": 22, "z": 45},
        {"x": 14, "y": 22, "z": 25}
      ],
      "dialogue": {
        "id": "ranger_talk",
        "startNodeId": "greet",
        "nodes": [
          {
            "id": "greet",
            "speaker": "Ranger Kira",
            "text": "Hold. You don't look like a villager. State your business.",
            "choices": [
              {"text": "The Elder sent me about the lost expedition.", "nextNodeId": "expedition"},
              {"text": "Just passing through.", "nextNodeId": "warning"}
            ]
          },
          {
            "id": "expedition",
            "speaker": "Ranger Kira",
            "text": "The expedition... I tracked them to the frozen temple northwest of here. I found supplies scattered in the snow but no bodies. Something drove them inside.",
            "choices": [
              {"text": "What's inside the temple?", "nextNodeId": "temple"},
              {"text": "I'll head there now.", "nextNodeId": "directions"}
            ]
          },
          {
            "id": "temple",
            "speaker": "Ranger Kira",
            "text": "I don't know. I heard strange sounds from within — like wind through crystal. The walls glow. It's not natural ice.",
            "choices": [
              {"text": "How do I get there?", "nextNodeId": "directions"}
            ]
          },
          {
            "id": "directions",
            "speaker": "Ranger Kira",
            "text": "Head northwest from the village. You'll see the glow before you see the temple. The entrance faces south. And take this — you'll need warmth."
          },
          {
            "id": "warning",
            "speaker": "Ranger Kira",
            "text": "Then keep moving. These highlands aren't kind to wanderers."
          }
        ]
      },
      "storyCharacter": {
        "id": "ranger",
        "faction": "highland_village",
        "agencyLevel": 2,
        "traits": {
          "openness": 0.7,
          "conscientiousness": 0.8,
          "extraversion": 0.3,
          "agreeableness": 0.5,
          "neuroticism": 0.4
        },
        "goals": [
          {"id": "patrol", "description": "Patrol the village perimeter", "priority": 0.8},
          {"id": "track_expedition", "description": "Track the missing expedition members", "priority": 0.9}
        ],
        "roles": ["guide", "combat"]
      }
    },
    {
      "name": "Blacksmith_Torvin",
      "position": {"x": 40, "y": 22, "z": 40},
      "behavior": "idle",
      "dialogue": {
        "id": "smith_talk",
        "startNodeId": "greet",
        "nodes": [
          {
            "id": "greet",
            "speaker": "Torvin",
            "text": "*hammering metal* Another adventurer! My blades are the finest in the highlands. Interested?",
            "choices": [
              {"text": "What do you have?", "nextNodeId": "wares"},
              {"text": "Know anything about the frozen temple?", "nextNodeId": "temple"}
            ]
          },
          {
            "id": "wares",
            "speaker": "Torvin",
            "text": "I forge with highland metal — tougher than anything you'll find in the lowlands. Strong enough to cut through enchanted ice, if the stories are true."
          },
          {
            "id": "temple",
            "speaker": "Torvin",
            "text": "That cursed place? My brother was in the expedition. If you're going there, take one of my blades. You'll need something that can cut through more than just ice."
          }
        ]
      },
      "storyCharacter": {
        "id": "blacksmith",
        "faction": "highland_village",
        "agencyLevel": 1,
        "traits": {
          "openness": 0.3,
          "conscientiousness": 0.95,
          "extraversion": 0.6,
          "agreeableness": 0.7,
          "neuroticism": 0.2
        },
        "goals": [
          {"id": "forge", "description": "Forge the finest weapons in the highlands", "priority": 0.85},
          {"id": "find_brother", "description": "Learn the fate of his brother in the expedition", "priority": 0.9}
        ],
        "roles": ["merchant", "craftsman"]
      }
    },
    {
      "name": "Merchant_Yuki",
      "position": {"x": 22, "y": 22, "z": 35},
      "behavior": "idle",
      "dialogue": {
        "id": "merchant_talk",
        "startNodeId": "greet",
        "nodes": [
          {
            "id": "greet",
            "speaker": "Yuki",
            "text": "Welcome! Hot soup, warm cloaks, healing herbs — everything a traveler needs for the frozen highlands!",
            "choices": [
              {"text": "I need supplies for a long trek.", "nextNodeId": "supplies"},
              {"text": "Have you heard of the frozen temple?", "nextNodeId": "temple"}
            ]
          },
          {
            "id": "supplies",
            "speaker": "Yuki",
            "text": "You're heading into the mountains? Take extra frostroot — it keeps the cold from your bones. And don't forget torches. The nights up there are pitch black."
          },
          {
            "id": "temple",
            "speaker": "Yuki",
            "text": "My grandmother used to tell stories about it. She said it was built by people who could shape ice like stone. They vanished long ago, but the temple remains."
          }
        ]
      },
      "storyCharacter": {
        "id": "merchant",
        "faction": "highland_village",
        "agencyLevel": 1,
        "traits": {
          "openness": 0.8,
          "conscientiousness": 0.6,
          "extraversion": 0.9,
          "agreeableness": 0.85,
          "neuroticism": 0.3
        },
        "goals": [
          {"id": "trade", "description": "Run a successful trading post", "priority": 0.7},
          {"id": "preserve_lore", "description": "Preserve highland stories and traditions", "priority": 0.6}
        ],
        "roles": ["merchant"]
      }
    }
