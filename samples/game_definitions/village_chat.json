{
  "name": "Village Chat",
  "description": "A simple conversation game. Walk up to the Blacksmith or the Herbalist and press E to talk.",
  "version": "1.0",

  "world": {
    "type": "Flat",
    "seed": 42,
    "from": {"x": 0, "y": 0, "z": 0},
    "to":   {"x": 0, "y": 0, "z": 0}
  },

  "camera": {
    "position": {"x": 16, "y": 25, "z": 28},
    "yaw": -90,
    "pitch": -25
  },

  "player": {
    "type": "physics",
    "position": {"x": 16, "y": 20, "z": 20}
  },

  "structures": [
    {
      "type": "fill",
      "from": {"x": 8, "y": 16, "z": 8},
      "to":   {"x": 24, "y": 16, "z": 24},
      "material": "Stone",
      "_comment": "Stone plaza floor on top of flat terrain"
    },
    {
      "type": "fill",
      "from": {"x": 15, "y": 17, "z": 15},
      "to":   {"x": 17, "y": 17, "z": 15},
      "material": "glow",
      "_comment": "Glowing marker between the two NPCs"
    }
  ],

  "npcs": [
    {
      "name": "Blacksmith",
      "position": {"x": 12, "y": 17, "z": 15},
      "animFile": "character.anim",
      "behavior": "idle",
      "dialogue": {
        "id": "blacksmith_talk",
        "startNodeId": "greeting",
        "nodes": [
          {
            "id": "greeting",
            "speaker": "Blacksmith",
            "text": "Hey there! Name's Tormund. I run the forge around here.",
            "emotion": "friendly",
            "choices": [
              {"text": "What do you make?", "nextNodeId": "wares"},
              {"text": "Know anything interesting?", "nextNodeId": "rumor"},
              {"text": "See you around.", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "wares",
            "speaker": "Blacksmith",
            "text": "Swords, shields, plows — you name it. Metal and fire, that's my trade.",
            "emotion": "proud",
            "choices": [
              {"text": "Impressive! Anything else?", "nextNodeId": "rumor"},
              {"text": "Thanks, Tormund.", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "rumor",
            "speaker": "Blacksmith",
            "text": "Well... the Herbalist next door has been acting strange. Muttering about some rare flower in the caves. You might want to ask her about it.",
            "emotion": "curious",
            "choices": [
              {"text": "I'll talk to her.", "nextNodeId": "bye"},
              {"text": "Caves? Sounds dangerous.", "nextNodeId": "caves"}
            ]
          },
          {
            "id": "caves",
            "speaker": "Blacksmith",
            "text": "Dangerous? Maybe. But the Herbalist swears that flower can cure anything. Worth a look if you ask me.",
            "emotion": "thoughtful",
            "choices": [
              {"text": "I'll check it out. Thanks!", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "bye",
            "speaker": "Blacksmith",
            "text": "Take care out there. Swing by anytime!",
            "emotion": "friendly"
          }
        ]
      },
      "storyCharacter": {
        "id": "blacksmith",
        "faction": "village",
        "agencyLevel": 0,
        "traits": {"openness": 0.5, "conscientiousness": 0.8, "extraversion": 0.7},
        "goals": [{"id": "forge", "description": "Keep the forge running", "priority": 0.8}]
      }
    },
    {
      "name": "Herbalist",
      "position": {"x": 20, "y": 17, "z": 15},
      "animFile": "character.anim",
      "behavior": "idle",
      "dialogue": {
        "id": "herbalist_talk",
        "startNodeId": "greeting",
        "nodes": [
          {
            "id": "greeting",
            "speaker": "Herbalist",
            "text": "Oh! A visitor. I'm Elara. I tend the herbs and remedies for the village.",
            "emotion": "neutral",
            "choices": [
              {"text": "What kind of remedies?", "nextNodeId": "remedies"},
              {"text": "The Blacksmith mentioned a rare flower.", "nextNodeId": "flower"},
              {"text": "Just saying hello. Bye!", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "remedies",
            "speaker": "Herbalist",
            "text": "Healing salves, antidotes, tonics for fatigue. Nothing too fancy — but they work!",
            "emotion": "proud",
            "choices": [
              {"text": "Tell me about that rare flower.", "nextNodeId": "flower"},
              {"text": "Good to know. Thanks!", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "flower",
            "speaker": "Herbalist",
            "text": "The Moonpetal! It only blooms deep in the caves to the north. They say it can cure any ailment. I've been trying to find one for months...",
            "emotion": "worried",
            "choices": [
              {"text": "I could look for it.", "nextNodeId": "quest_accept"},
              {"text": "Sounds risky. Good luck.", "nextNodeId": "quest_decline"}
            ]
          },
          {
            "id": "quest_accept",
            "speaker": "Herbalist",
            "text": "You would? That would mean the world to me! Head north past the plaza — the cave entrance should be visible. Be careful in there!",
            "emotion": "grateful",
            "choices": [
              {"text": "I'll find it. Count on me!", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "quest_decline",
            "speaker": "Herbalist",
            "text": "I understand. It's not an easy ask. If you change your mind, I'll be here.",
            "emotion": "sad",
            "choices": [
              {"text": "Maybe later. Goodbye.", "nextNodeId": "bye"}
            ]
          },
          {
            "id": "bye",
            "speaker": "Herbalist",
            "text": "Stay safe, traveler. May the herbs be ever in your favor!",
            "emotion": "friendly"
          }
        ]
      },
      "storyCharacter": {
        "id": "herbalist",
        "faction": "village",
        "agencyLevel": 0,
        "traits": {"openness": 0.9, "conscientiousness": 0.7, "extraversion": 0.4},
        "goals": [{"id": "moonpetal", "description": "Find the Moonpetal flower", "priority": 0.9}]
      }
    }
  ],

  "story": {
    "arcs": [
      {
        "id": "moonpetal_quest",
        "name": "The Moonpetal",
        "constraintMode": "Guided",
        "beats": [
          {
            "id": "meet_blacksmith",
            "description": "Talk to the Blacksmith and learn about the Herbalist",
            "type": "Soft"
          },
          {
            "id": "meet_herbalist",
            "description": "Speak with the Herbalist about the Moonpetal flower",
            "type": "Hard"
          }
        ]
      }
    ]
  }
}
