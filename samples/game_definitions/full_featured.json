  "npcs": [
    {
      "name": "Castle Guard",
      "position": {
        "x": 16,
        "y": 34,
        "z": 12
      },
      "type": "animated",
      "animation": "character_complete.anim",
      "behavior": "patrol",
      "waypoints": [
        {
          "x": 12,
          "y": 34,
          "z": 12
        },
        {
          "x": 20,
          "y": 34,
          "z": 12
        }
      ],
      "dialogue": {
        "id": "guard_talk",
        "startNodeId": "start",
        "nodes": [
          {
            "id": "start",
            "speaker": "Castle Guard",
            "text": "Halt! Who goes there? State your business in the Enchanted Realms.",
            "choices": [
              {
                "text": "I seek the Crystal of Power.",
                "nextNodeId": "crystal_quest"
              },
              {
                "text": "Just exploring.",
                "nextNodeId": "explore"
              }
            ]
          },
          {
            "id": "crystal_quest",
            "speaker": "Castle Guard",
            "text": "The Crystal? It was stolen by the Shadow Mage who lives in the Ice Tower to the northwest. The King has offered a great reward for its return."
          },
          {
            "id": "explore",
            "speaker": "Castle Guard",
            "text": "Welcome then, traveler. The village is south of the castle. Visit the Blacksmith for supplies."
          }
        ]
      },
      "storyCharacter": {
        "id": "guard",
        "faction": "kingdom",
        "agencyLevel": 1,
        "traits": {
          "openness": 0.3,
          "conscientiousness": 0.9,
          "extraversion": 0.5
        },
        "goals": [
          {
            "id": "protect_castle",
            "description": "Protect the castle gates",
            "priority": 0.95
          }
        ]
      }
    },
    {
      "name": "Blacksmith Goroth",
      "position": {
        "x": -2,
        "y": 27,
        "z": -2
      },
      "type": "animated",
      "animation": "character_complete.anim",
      "behavior": "stationary",
      "dialogue": {
        "id": "blacksmith_talk",
        "startNodeId": "start",
        "nodes": [
          {
            "id": "start",
            "speaker": "Blacksmith Goroth",
            "text": "Welcome to my forge! I craft the finest weapons in the realm. What can I do for you?",
            "choices": [
              {
                "text": "Tell me about the Shadow Mage.",
                "nextNodeId": "shadow_mage"
              },
              {
                "text": "What do you sell?",
                "nextNodeId": "shop"
              }
            ]
          },
          {
            "id": "shadow_mage",
            "speaker": "Blacksmith Goroth",
            "text": "That dark sorcerer? He appeared a fortnight ago and stole the Crystal from the castle tower. His Ice Tower is dangerous - you'll need strong equipment."
          },
          {
            "id": "shop",
            "speaker": "Blacksmith Goroth",
            "text": "I have swords of metal and shields of stone. Take what you need, adventurer!"
          }
        ]
      },
      "storyCharacter": {
        "id": "blacksmith",
        "faction": "village",
        "agencyLevel": 2,
        "traits": {
          "openness": 0.6,
          "conscientiousness": 0.8,
          "extraversion": 0.7
        },
        "goals": [
          {
            "id": "serve_customers",
            "description": "Help adventurers with equipment",
            "priority": 0.8
          }
        ]
      }
    },
    {
      "name": "Elder Mirwen",
      "position": {
        "x": 33,
        "y": 27,
        "z": 33
      },
      "type": "animated",
      "animation": "character_complete.anim",
      "behavior": "stationary",
      "dialogue": {
        "id": "elder_talk",
        "startNodeId": "start",
        "nodes": [
          {
            "id": "start",
            "speaker": "Elder Mirwen",
            "text": "Greetings, young one. I sense great destiny about you. The Enchanted Realms need a hero.",
            "choices": [
              {
                "text": "What happened to these lands?",
                "nextNodeId": "history"
              },
              {
                "text": "How can I help?",
                "nextNodeId": "quest"
              }
            ]
          },
          {
            "id": "history",
            "speaker": "Elder Mirwen",
            "text": "Once, the Crystal of Power kept these lands in balance. Its light warded off darkness. But the Shadow Mage took it, and now ice creeps across the northwest mountains."
          },
          {
            "id": "quest",
            "speaker": "Elder Mirwen",
            "text": "Journey to the Ice Tower in the northwest. Defeat the Shadow Mage and return the Crystal to its rightful place atop the Castle Tower. Only then will peace return."
          }
        ]
      },
      "storyCharacter": {
        "id": "elder",
        "faction": "village",
        "agencyLevel": 3,
        "traits": {
          "openness": 0.9,
          "conscientiousness": 0.7,
          "extraversion": 0.4
        },
        "goals": [
          {
            "id": "guide_hero",
            "description": "Guide the hero to save the realm",
            "priority": 0.99
          }
        ]
      }
    },
    {
      "name": "Shadow Mage",
      "position": {
        "x": -9,
        "y": 29,
        "z": 31
      },
      "type": "animated",
      "animation": "character_complete.anim",
      "behavior": "stationary",
      "dialogue": {
        "id": "mage_talk",
        "startNodeId": "start",
        "nodes": [
          {
            "id": "start",
            "speaker": "Shadow Mage",
            "text": "You dare enter my domain? The Crystal's power is MINE now!",
            "choices": [
              {
                "text": "Return the Crystal or face justice!",
                "nextNodeId": "fight"
              },
              {
                "text": "Why did you take it?",
                "nextNodeId": "motive"
              }
            ]
          },
          {
            "id": "fight",
            "speaker": "Shadow Mage",
            "text": "Then prepare yourself, fool! You will become another ice statue in my collection!"
          },
          {
            "id": "motive",
            "speaker": "Shadow Mage",
            "text": "The kingdom banished me! They feared my power. Now they will fear the eternal winter I bring!"
          }
        ]
      },
      "storyCharacter": {
        "id": "shadow_mage",
        "faction": "shadow",
        "agencyLevel": 3,
        "traits": {
          "openness": 0.4,
          "conscientiousness": 0.6,
          "extraversion": 0.3
        },
        "goals": [
          {
            "id": "conquer",
            "description": "Plunge the realm into eternal winter",
            "priority": 0.95
          }
        ]
      }
    }
  ],
