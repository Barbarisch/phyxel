#version 450
#extension GL_GOOGLE_include_directive : require
#include "particle_types.glsl"
#include "solver_types.glsl"

layout(local_size_x = WORKGROUP_SOLVER) in;

layout(std430, set=0, binding=0) buffer SolverBodyBuffer        { SolverBody  bodies[]; };
layout(std430, set=0, binding=1) readonly buffer MaterialBuffer { MaterialPhysics materials[]; };
layout(std430, set=0, binding=2) readonly buffer ParticleBuffer { GpuParticle particles[]; };

// Player character collider — uploaded each frame from the CPU (setCharacterColliders).
// Header = broadphase union AABB + velocity (first 48 bytes match the legacy single-AABB
// layout in particle_collide.comp). charSeg[] holds the per-limb body-part boxes; debris
// overlapping a segment is shoved out + inherits the character's velocity, letting the
// player plow through debris piles with arms/legs, not just the torso. This is the
// AVBD-pipeline equivalent of the legacy XPBD character collision (no longer dispatched).
struct CharSegment {
    vec4 center;       // xyz = world center
    vec4 halfExtents;  // xyz = world half-extents
};
layout(std430, set=0, binding=3) readonly buffer CharacterBuffer {
    vec3  charUnionCenter;       float charSegCount;   // # active segments (0 = disabled)
    vec3  charUnionHalfExtents;  float charPad0;
    vec3  charVelocity;          float charPad1;
    CharSegment charSeg[12];     // == GpuParticlePhysics::MAX_CHAR_SEGMENTS
};

// AABB overlap + shortest-axis push-out. Returns true if the body AABB (bpos +/- bhe)
// overlaps the box (cpos +/- che); if so, outDisp = displacement that moves the body
// out of the box along the axis of least penetration.
bool aabbPushOut(vec3 bpos, vec3 bhe, vec3 cpos, vec3 che, out vec3 outDisp) {
    outDisp = vec3(0.0);
    vec3 pMin = bpos - bhe;  vec3 pMax = bpos + bhe;
    vec3 cMin = cpos - che;  vec3 cMax = cpos + che;
    if (!(pMin.x < cMax.x && pMax.x > cMin.x &&
          pMin.y < cMax.y && pMax.y > cMin.y &&
          pMin.z < cMax.z && pMax.z > cMin.z)) return false;

    float penPX = cMax.x - pMin.x;  float penNX = pMax.x - cMin.x;
    float penPY = cMax.y - pMin.y;  float penNY = pMax.y - cMin.y;
    float penPZ = cMax.z - pMin.z;  float penNZ = pMax.z - cMin.z;

    float minPen = penPX;  int axis = 0;
    if (penNX < minPen) { minPen = penNX; axis = 1; }
    if (penPY < minPen) { minPen = penPY; axis = 2; }
    if (penNY < minPen) { minPen = penNY; axis = 3; }
    if (penPZ < minPen) { minPen = penPZ; axis = 4; }
    if (penNZ < minPen) { minPen = penNZ; axis = 5; }

    if      (axis == 0) outDisp.x =  minPen;
    else if (axis == 1) outDisp.x = -minPen;
    else if (axis == 2) outDisp.y =  minPen;
    else if (axis == 3) outDisp.y = -minPen;
    else if (axis == 4) outDisp.z =  minPen;
    else                outDisp.z = -minPen;
    return true;
}

layout(push_constant) uniform PC {
    uint  count;
    float dt;
    float gravity;
    float pad;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.count) return;

    SolverBody b = bodies[i];

    if ((b.flags & PARTICLE_ACTIVE) == 0u || b.invMass == 0.0) {
        // Static/inactive: save initial, stay in place
        b.initial      = b.pos;
        b.initialQuat  = b.quat;
        b.inertial     = b.pos;
        b.inertialQuat = b.quat;
        b.cumAng       = vec3(0.0);
        bodies[i] = b;
        return;
    }

    GpuParticle     p   = particles[b.particleIdx];
    MaterialPhysics mat = materials[p.materialIndex];

    // Save state before any forces (these are the "initial" AVBD reference values)
    b.prevVel     = b.vel;
    b.initial     = b.pos;
    b.initialQuat = b.quat;

    // ---- Adaptive accelWeight (Shallot-style; AVBD paper §4) ----------------
    // At rest, predicting body.pos with full gravity moves it DOWN by ~g*dt² each
    // frame, forcing narrowphase to re-emit fresh penetration → tug-of-war between
    // gravity step and solver pushback → vibration / popcorn.
    //
    // Shallot uses accelWeight = clamp(actual_accel.y * sign(g) / |g|, 0, 1):
    // 0 at rest (constraints cancel gravity), 1 in free fall. This requires prevVel
    // persisted across frames; our sync_in resets prevVel each frame, so we use a
    // velocity-magnitude heuristic instead — same outcome for the resting case.
    //   speed² < REST_SQ  → accelWeight ≈ 0 → body.pos NOT pushed by gravity
    //   speed² > MOVE_SQ  → accelWeight = 1 → full free-fall prediction
    float speedSq = dot(b.vel, b.vel);
    const float REST_SQ = 0.01;     // (0.1 m/s)²
    const float MOVE_SQ = 1.0;      // (1.0 m/s)²
    float accelWeight = clamp((speedSq - REST_SQ) / (MOVE_SQ - REST_SQ), 0.0, 1.0);

    // Apply external forces: gravity + damping
    b.vel.y   += pc.gravity * pc.dt;
    b.vel     *= mat.linearDamp  * GAMMA;
    b.angVel  *= mat.angularDamp * GAMMA;

    // Inertial (unconstrained) prediction: where the body goes with no contacts.
    // Used as the energy minimum in primal/dual — solver pulls body toward it.
    b.inertial     = b.pos + b.vel * pc.dt;
    b.inertialQuat = quatIntegrate(b.quat, b.angVel * pc.dt);

    // Adaptive starting iterate for body.pos. After applying gravity above we have
    //   b.vel * dt = b.vel_old * dt + g*dt²        (gravity already baked in)
    // Subtracting (1-accelWeight)*g*dt² removes the gravity component for at-rest
    // bodies, so narrowphase sees the same position as last frame → no fresh
    // penetration → λ stays steady. In free-fall (accelWeight=1) this collapses
    // to the full inertial prediction.
    float gravBackoff = (1.0 - accelWeight) * pc.gravity * pc.dt * pc.dt;
    b.pos  = b.inertial - vec3(0.0, gravBackoff, 0.0);
    b.quat = b.inertialQuat;

    // Seed cumAng with the angular displacement accumulated during force integration
    b.cumAng = angDispFromInitial(b.inertialQuat, b.initialQuat);

    // ---- Character per-limb push (external influence, applied after prediction) ----
    // Ported/extended from the legacy XPBD particle_collide.comp character block.
    // Treats the body's OBB as an AABB for a cheap shove (matches legacy). We first
    // test the broadphase union AABB so the common case (debris far from the player)
    // costs a single test; only on a union hit do we scan the per-limb segment boxes.
    // On the first overlapping segment we push the body out along the shortest exit
    // axis, give it the character's velocity (boosted for a lively shove) + a small
    // upward pop, and RE-ANCHOR the AVBD inertial target to the pushed state —
    // otherwise the solver pulls the body straight back. The later voxel-contact pass
    // still resolves any push-into-floor, so debris can't sink.
    if (charSegCount > 0.5) {
        vec3 he = b.halfExt;
        vec3 disp;
        if (aabbPushOut(b.pos, he, charUnionCenter, charUnionHalfExtents, disp)) {
            int n = int(charSegCount);
            for (int s = 0; s < n && s < 12; ++s) {
                vec3 segDisp;
                if (aabbPushOut(b.pos, he, charSeg[s].center.xyz, charSeg[s].halfExtents.xyz, segDisp)) {
                    b.pos += segDisp;

                    vec3 pushVel = charVelocity * 1.25;
                    pushVel.y   += 0.5;
                    b.vel        = pushVel;
                    b.angVel    += vec3(-charVelocity.z, 0.0, charVelocity.x);

                    b.inertial     = b.pos + b.vel * pc.dt;
                    b.inertialQuat = quatIntegrate(b.quat, b.angVel * pc.dt);
                    b.cumAng       = angDispFromInitial(b.inertialQuat, b.initialQuat);
                    break;
                }
            }
        }
    }

    bodies[i] = b;
}
