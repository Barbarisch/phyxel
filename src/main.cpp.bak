float randomFloat(float strength = 2.0f) {
    static std::mt19937 rng(std::random_device{}());
    std::uniform_real_distribution<float> dist(-strength, strength);
    return dist(rng);
}

struct QueueFamilyIndices {
    std::optional<uint32_t> graphicsFamily;
    std::optional<uint32_t> presentFamily;

    bool isComplete() {
        return graphicsFamily.has_value() && presentFamily.has_value();
    }
};

QueueFamilyIndices findQueueFamilies(VkPhysicalDevice device, VkSurfaceKHR surface) {
    QueueFamilyIndices indices;

    uint32_t queueFamilyCount = 0;
    vkGetPhysicalDeviceQueueFamilyProperties(device, &queueFamilyCount, nullptr);

    std::vector<VkQueueFamilyProperties> queueFamilies(queueFamilyCount);
    vkGetPhysicalDeviceQueueFamilyProperties(device, &queueFamilyCount, queueFamilies.data());

    int i = 0;
    for (const auto& queueFamily : queueFamilies) {
        if (queueFamily.queueFlags & VK_QUEUE_GRAPHICS_BIT) {
            indices.graphicsFamily = i;
        }

        VkBool32 presentSupport = false;
        vkGetPhysicalDeviceSurfaceSupportKHR(device, i, surface, &presentSupport);
        if (presentSupport) {
            indices.presentFamily = i;
        }

        if (indices.isComplete()) break;
        i++;
    }

    return indices;
}

struct InstanceData {
    glm::vec3 offset;
    glm::vec3 color;
    uint32_t faceMask;  // 6 bits for face visibility: bit0=front, bit1=back, bit2=right, bit3=left, bit4=top, bit5=bottom
};

inline VkVertexInputBindingDescription getInstanceBindingDescription() {
    VkVertexInputBindingDescription desc{};
    desc.binding = 1;  // Unified binding for offset and color
    desc.stride = sizeof(InstanceData);  // Whole struct
    desc.inputRate = VK_VERTEX_INPUT_RATE_INSTANCE;
    return desc;
}

inline VkVertexInputAttributeDescription getInstanceAttributeDescription() {
    VkVertexInputAttributeDescription desc{};
    desc.binding = 1;       // Match buffer binding
    desc.location = 1;      // Shader layout(location = 1)
    desc.format = VK_FORMAT_R32G32B32_SFLOAT;
    desc.offset = offsetof(InstanceData, offset);  // Correct offset into struct
    return desc;
}

inline VkVertexInputAttributeDescription getInstanceColorAttributeDescription() {
    VkVertexInputAttributeDescription desc{};
    desc.binding = 1;       // Same buffer
    desc.location = 2;      // Shader layout(location = 2)
    desc.format = VK_FORMAT_R32G32B32_SFLOAT;
    desc.offset = offsetof(InstanceData, color);  // Correct offset into struct
    return desc;
}

inline VkVertexInputAttributeDescription getInstanceFaceMaskAttributeDescription() {
    VkVertexInputAttributeDescription desc{};
    desc.binding = 1;       // Same buffer as other instance data
    desc.location = 3;      // Shader layout(location = 3) 
    desc.format = VK_FORMAT_R32_UINT;  // 32-bit unsigned integer for face mask
    desc.offset = offsetof(InstanceData, faceMask);  // Correct offset into struct
    return desc;
}

static std::vector<char> readFile(const std::string& filename) {
    std::ifstream file(filename, std::ios::ate | std::ios::binary);
    if (!file.is_open()) throw std::runtime_error("Failed to open file!");

    size_t fileSize = (size_t) file.tellg();
    std::vector<char> buffer(fileSize);

    file.seekg(0);
    file.read(buffer.data(), fileSize);
    file.close();

    return buffer;
}

// frustum culling
struct AABB {
    glm::vec3 min;
    glm::vec3 max;
};
