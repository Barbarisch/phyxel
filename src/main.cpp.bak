    // indirect rendering
    void createIndirectDrawBuffer() {
        VkDeviceSize bufferSize = sizeof(VkDrawIndirectCommand);

        createBuffer(bufferSize,
                    VK_BUFFER_USAGE_INDIRECT_BUFFER_BIT | VK_BUFFER_USAGE_STORAGE_BUFFER_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT,
                    VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT,
                    indirectDrawBuffer,
                    indirectDrawBufferMemory);

        std::cout << "✅ Created indirect draw buffer\n";
    }

    void createDrawCommandBuffer() {
        VkDeviceSize bufferSize = sizeof(VkDrawIndexedIndirectCommand);  // Fix: Use correct struct size

        createBuffer(bufferSize,
                    VK_BUFFER_USAGE_INDIRECT_BUFFER_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT | VK_BUFFER_USAGE_STORAGE_BUFFER_BIT,
                    VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT | VK_MEMORY_PROPERTY_HOST_COHERENT_BIT,
                    drawCommandBuffer,
                    drawCommandBufferMemory);

        std::cout << "✅ Created drawCommandBuffer" << std::endl;
    }

    void updateDrawCommandBuffer(uint32_t visibleCount) {
        VkDrawIndexedIndirectCommand drawCmd{};  // Fix: Use correct struct type
        drawCmd.indexCount    = static_cast<uint32_t>(indices.size());  // Number of indices (36)
        drawCmd.instanceCount = visibleCount;
        drawCmd.firstIndex    = 0;
        drawCmd.vertexOffset  = 0;
        drawCmd.firstInstance = 0;

        void* data;
        vkMapMemory(device, drawCommandBufferMemory, 0, sizeof(drawCmd), 0, &data);
        memcpy(data, &drawCmd, sizeof(drawCmd));
        vkUnmapMemory(device, drawCommandBufferMemory);
    }
    ///////

    // physics
    btRigidBody* createFallingCube(btDiscreteDynamicsWorld* world, const btVector3& position) {
        // Box shape with 1x1x1 size
        btCollisionShape* boxShape = new btBoxShape(btVector3(0.5f, 0.5f, 0.5f));

        // Set up mass and inertia
        btScalar mass = 1.0f;
        btVector3 inertia(0, 0, 0);
        boxShape->calculateLocalInertia(mass, inertia);

        // Motion state
        btDefaultMotionState* motionState = new btDefaultMotionState(btTransform(
            btQuaternion(0, 0, 0, 1),
            position
        ));

        // Construction info
        btRigidBody::btRigidBodyConstructionInfo info(mass, motionState, boxShape, inertia);
        btRigidBody* body = new btRigidBody(info);

        // Add to world
        world->addRigidBody(body);

        std::cout << "🧱 Created dynamic cube at " 
                << position.getX() << ", " << position.getY() << ", " << position.getZ() << "\n";

        return body;
    }

    btRigidBody* createStaticCube(btDiscreteDynamicsWorld* world, const btVector3& position) {
        btCollisionShape* shape = new btBoxShape(btVector3(0.5f, 0.5f, 0.5f));
        btTransform transform(btQuaternion(0, 0, 0, 1), position);
        btDefaultMotionState* motion = new btDefaultMotionState(transform);
        btRigidBody::btRigidBodyConstructionInfo info(0.0f, motion, shape, btVector3(0, 0, 0)); // ← mass = 0
        btRigidBody* body = new btRigidBody(info);
        world->addRigidBody(body);
        return body;
    }
    
    void breakCube(Cube* cube) {
        // Create physics cube at same location
        if (cube && !cube->broken) {
            cube->broken = true;

            // Remove static body from physics world
            if (cube->rigidBody) {
                dynamicsWorld->removeRigidBody(cube->rigidBody);
                delete cube->rigidBody->getMotionState();
                delete cube->rigidBody->getCollisionShape();
                delete cube->rigidBody;
                cube->rigidBody = nullptr;
            }
            // Create dynamic body
            // btRigidBody* dynamic = createFallingCube(dynamicsWorld, btVector3(cube->position.x, cube->position.y, cube->position.z));

            // // Apply linear impulse
            // btVector3 impulse(randomFloat(), randomFloat(), randomFloat());
            // dynamic->applyCentralImpulse(impulse);

            // // Apply angular impulse (spin)
            // btVector3 angularImpulse(randomFloat(), randomFloat(), randomFloat());
            // dynamic->applyTorqueImpulse(angularImpulse);

            // cube->rigidBody = dynamic;

            // fallingCubeBodies.push_back(dynamic);
            // fallingCubeColors.push_back(cube->color);
            spawnSubcubes(cube->position);
        }
    }
    ////////

    void spawnSubcubes(const glm::vec3& center) {
        float spacing = 1.0f / 3.0f;  // Small spacing for 3x3x3 grid
        float start = -spacing;      // Centered around 0

        for (int x = 0; x < 3; ++x) {
            for (int y = 0; y < 3; ++y) {
                for (int z = 0; z < 3; ++z) {
                    glm::vec3 offset = glm::vec3(
                        start + x * spacing,
                        start + y * spacing,
                        start + z * spacing
                    );

                    glm::vec3 position = center + offset;
                    btVector3 btPos(position.x, position.y, position.z);

                    btCollisionShape* shape = new btBoxShape(btVector3(0.15f, 0.15f, 0.15f));
                    btScalar mass = 0.1f;
                    btVector3 inertia(0, 0, 0);
                    shape->calculateLocalInertia(mass, inertia);

                    btDefaultMotionState* motion = new btDefaultMotionState(btTransform(
                        btQuaternion(0, 0, 0, 1), btPos));

                    btRigidBody::btRigidBodyConstructionInfo info(mass, motion, shape, inertia);
                    btRigidBody* body = new btRigidBody(info);

                    // Give it a small random nudge
                    float fx = ((rand() % 100) / 50.0f - 1.0f) * 5.0f;
                    float fy = ((rand() % 100) / 50.0f) * 8.0f;
                    float fz = ((rand() % 100) / 50.0f - 1.0f) * 5.0f;
                    body->applyCentralImpulse(btVector3(fx, fy, fz));

                    dynamicsWorld->addRigidBody(body);

                    glm::vec3 color = glm::vec3(1.0f, 0.7f, 0.2f); // could inherit from parent

                    subcubes.push_back({ body, color, glfwGetTime() });
                }
            }
        }
    }

    // timing profile stuff
    void createTimestampQueryPool() {
        VkQueryPoolCreateInfo queryPoolInfo{};
        queryPoolInfo.sType = VK_STRUCTURE_TYPE_QUERY_POOL_CREATE_INFO;
        queryPoolInfo.queryType = VK_QUERY_TYPE_TIMESTAMP;
        queryPoolInfo.queryCount = 4; // Start/end for CPU work and GPU work
        
        if (vkCreateQueryPool(device, &queryPoolInfo, nullptr, &timestampQueryPool) != VK_SUCCESS) {
            throw std::runtime_error("Failed to create query pool!");
        }
        
        timestampResults.resize(4);
        
        // Get timestamp period for converting to milliseconds
        VkPhysicalDeviceProperties properties;
        vkGetPhysicalDeviceProperties(physicalDevice, &properties);
        timestampPeriod = properties.limits.timestampPeriod;
    }

    FrameTiming profileFrame() {
        FrameTiming timing;
        
        // CPU timing
        auto cpuStart = std::chrono::high_resolution_clock::now();
        
        // Read actual visibility results from GPU after frustum culling using staging buffer
        std::vector<uint32_t> visibleFlags(renderInstances.size());
        VkDeviceSize bufferSize = visibleFlags.size() * sizeof(uint32_t);
        
        VkBuffer stagingBuffer;
        VkDeviceMemory stagingBufferMemory;
        createBuffer(bufferSize, VK_BUFFER_USAGE_TRANSFER_DST_BIT,
                    VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT | VK_MEMORY_PROPERTY_HOST_COHERENT_BIT,
                    stagingBuffer, stagingBufferMemory);

        copyBuffer(visibleBuffer, stagingBuffer, bufferSize);

        void* mapped;
        vkMapMemory(device, stagingBufferMemory, 0, bufferSize, 0, &mapped);
        memcpy(visibleFlags.data(), mapped, bufferSize);
        vkUnmapMemory(device, stagingBufferMemory);

        vkDestroyBuffer(device, stagingBuffer, nullptr);
        vkFreeMemory(device, stagingBufferMemory, nullptr);
        
        // Count actual visible instances after frustum culling
        timing.visibleInstances = std::count(visibleFlags.begin(), visibleFlags.end(), 1u);
        timing.culledInstances = renderInstances.size() - timing.visibleInstances;
        
        // Estimate vertex count (36 indices per cube * actually visible cubes)
        timing.vertexCount = timing.visibleInstances * 36;
        
        // Draw calls (you're using indirect, so probably 1)
        timing.drawCalls = 1;
        
        auto cpuEnd = std::chrono::high_resolution_clock::now();
        timing.cpuFrameTime = std::chrono::duration<double, std::milli>(cpuEnd - cpuStart).count();
        
        return timing;
    }

    void printProfilingInfo(int fps) {
        if (frameTimings.empty()) return;
        
        // Calculate averages
        double avgCpuTime = 0.0;
        int avgVertices = 0;
        int avgVisible = 0;
        int avgCulled = 0;
        
        for (const auto& timing : frameTimings) {
            avgCpuTime += timing.cpuFrameTime;
            avgVertices += timing.vertexCount;
            avgVisible += timing.visibleInstances;
            avgCulled += timing.culledInstances;
        }
        
        int samples = frameTimings.size();
        avgCpuTime /= samples;
        avgVertices /= samples;
        avgVisible /= samples;
        avgCulled /= samples;
        
        std::cout << "\n=== FRAME PROFILING ===\n";
        std::cout << "FPS: " << fps << "\n";
        std::cout << "Avg CPU Frame Time: " << avgCpuTime << "ms\n";
        std::cout << "Avg Vertices/Frame: " << avgVertices << "\n";
        std::cout << "Avg Visible Cubes: " << avgVisible << "\n";
        std::cout << "Avg Culled Cubes: " << avgCulled << "\n";
        std::cout << "Culling Efficiency: " << (100.0 * avgCulled / (avgVisible + avgCulled)) << "%\n";
        std::cout << "Memory Usage: Instance Buffer = " << (avgVisible * sizeof(InstanceData)) << " bytes\n";
        std::cout << "======================\n";
    }

    void printMemoryUsage() {
        VkPhysicalDeviceMemoryProperties memProps;
        vkGetPhysicalDeviceMemoryProperties(physicalDevice, &memProps);
        
        std::cout << "GPU Memory Heaps:\n";
        for (uint32_t i = 0; i < memProps.memoryHeapCount; i++) {
            std::cout << "  Heap " << i << ": " << (memProps.memoryHeaps[i].size / 1024 / 1024) << " MB\n";
        }
    }

    void printDetailedTimings() {
        if (detailedTimings.empty()) return;
        
        // Calculate averages
        DetailedFrameTiming avg = {};
        for (const auto& t : detailedTimings) {
            avg.totalFrameTime += t.totalFrameTime;
            avg.mousePickTime += t.mousePickTime;
            avg.uboFillTime += t.uboFillTime;
            avg.instanceUpdateTime += t.instanceUpdateTime;
            avg.drawCmdUpdateTime += t.drawCmdUpdateTime;
            avg.uniformUploadTime += t.uniformUploadTime;
            avg.commandRecordTime += t.commandRecordTime;
            avg.gpuSubmitTime += t.gpuSubmitTime;
            avg.presentTime += t.presentTime;
        }
        
        int samples = detailedTimings.size();
        avg.totalFrameTime /= samples;
        avg.mousePickTime /= samples;
        avg.uboFillTime /= samples;
        avg.instanceUpdateTime /= samples;
        avg.drawCmdUpdateTime /= samples;
        avg.uniformUploadTime /= samples;
        avg.commandRecordTime /= samples;
        avg.gpuSubmitTime /= samples;
        avg.presentTime /= samples;
        
        std::cout << "\n=== DETAILED FRAME TIMING ===\n";
        std::cout << "Total Frame Time: " << avg.totalFrameTime << "ms\n";
        std::cout << "  Mouse Picking: " << avg.mousePickTime << "ms\n";
        std::cout << "  UBO Fill: " << avg.uboFillTime << "ms\n";
        std::cout << "  Instance Update: " << avg.instanceUpdateTime << "ms\n";
        std::cout << "  Draw Cmd Update: " << avg.drawCmdUpdateTime << "ms\n";
        std::cout << "  Uniform Upload: " << avg.uniformUploadTime << "ms\n";
        std::cout << "  Command Record: " << avg.commandRecordTime << "ms\n";
        std::cout << "  GPU Submit: " << avg.gpuSubmitTime << "ms\n";
        std::cout << "  Present: " << avg.presentTime << "ms\n";
        std::cout << "=============================\n";
    }
};

int main() {
    VulkanApp app;
    try {
        app.run();
    } catch (const std::exception& e) {
        std::cerr << e.what() << std::endl;
        return EXIT_FAILURE;
    }
    return EXIT_SUCCESS;
}
